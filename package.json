{
  "name": "bws",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "prettier . --check && cspell --dot --gitignore **/*.astro **/*.md* && astro check",
    "dev": "astro dev",
    "fmt": "prettier . --write",
    "preview": "astro preview",
    "start": "astro dev",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "vitest run"
  },
  "prettier": {
    "semi": false,
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      },
      {
        "files": [
          "COMMIT_EDITMSG"
        ],
        "options": {
          "parser": "markdown",
          "printWidth": 72,
          "proseWrap": "always"
        }
      }
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^7.1.0",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@pagefind/default-ui": "~1.4.0",
    "astro": "^6.1.3",
    "pagefind": "~1.4.0",
    "rehype": "~13.0.2",
    "rehype-autolink-headings": "^7.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "cspell": "^9.7.0",
    "prettier": "~3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23"
    }
  }
}
