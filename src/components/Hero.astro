---
interface Props {
  title: string
  tagline?: string
  align?: "start" | "center"
  classList?: string[]
  variant?: "default" | "home"
}

const {
  align = "center",
  classList = [],
  tagline,
  title,
  variant = "default",
} = Astro.props
---

{
  variant === "home" ? (
    <header class="home-hero">
      <div class="hero-copy">
        <div class:list={["hero stack gap-4", align]}>
          <div class="stack gap-2">
            <h1 class:list={classList.concat(["title"])}>{title}</h1>
            {tagline && <p class="tagline">{tagline}</p>}
          </div>
          <slot />
        </div>
      </div>
      <div class="hero-portrait">
        <slot name="portrait" />
      </div>
      <div class="hero-skills">
        <slot name="skills" />
      </div>
    </header>
  ) : (
    <div class:list={["hero stack gap-4", align]}>
      <div class="stack gap-2">
        <h1 class:list={classList.concat(["title"])}>{title}</h1>
        {tagline && <p class="tagline">{tagline}</p>}
      </div>
      <slot />
    </div>
  )
}

<style>
  .hero {
    font-size: var(--text-lg);
    text-align: center;
    white-space-collapse: preserve-breaks;
  }

  .title,
  .tagline {
    max-width: 45ch;
    margin-inline: auto;
  }

  .title {
    font-size: var(--text-2xl);
    color: var(--gray-0);
  }

  .home-hero {
    display: grid;
    grid-template-areas:
      "copy"
      "portrait"
      "skills";
    align-items: center;
    gap: 2rem;
  }

  .hero-copy {
    grid-area: copy;
  }

  .hero-portrait {
    grid-area: portrait;
  }

  .hero-skills {
    grid-area: skills;
  }

  .hero-portrait :global(img) {
    aspect-ratio: 5 / 4;
    object-fit: cover;
    object-position: center;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 50em) {
    .hero {
      font-size: var(--text-xl);
    }

    .title {
      font-size: var(--text-3xl);
    }

    .home-hero {
      grid-template-areas:
        "copy portrait"
        "skills skills";
      grid-template-columns: minmax(0, 1fr) minmax(14rem, 16rem);
      padding-inline: 1.5rem;
      column-gap: 2rem;
      row-gap: 2rem;
    }

    .hero-portrait {
      align-self: center;
    }

    .hero-portrait :global(img) {
      aspect-ratio: 3 / 4;
      border-radius: 4.5rem;
      object-fit: cover;
    }
  }

  @media (min-width: 64em) {
    .home-hero {
      grid-template-areas:
        "copy portrait"
        "skills portrait";
      grid-template-columns: minmax(0, 6fr) minmax(18rem, 4fr);
      padding-inline: 2.5rem;
      column-gap: 3.75rem;
      row-gap: 2.5rem;
    }
  }
</style>
