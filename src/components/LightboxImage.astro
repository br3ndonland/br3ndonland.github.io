---
import { Picture } from "astro:assets"
import type { ImageMetadata, ImageOutputFormat } from "astro"
import { PICTURE_FORMATS } from "@consts"

interface Props {
  alt: string
  decoding?: "async" | "auto" | "sync" | null | undefined
  description?: string | undefined
  formats?: ImageOutputFormat[] | undefined
  gallery?: string | undefined
  href?: string | undefined
  imageClass?: string | undefined
  loading?: "eager" | "lazy" | null | undefined
  src: ImageMetadata | string
  title?: string | undefined
}

const {
  alt,
  decoding = "async",
  description,
  formats = PICTURE_FORMATS,
  gallery,
  href,
  imageClass,
  loading = "lazy",
  src,
  title,
} = Astro.props

const imageHref = href ?? (typeof src === "string" ? src : src.src)
const imageTitle = title ?? (alt || undefined)
const ariaLabel = imageTitle ? `Open image: ${imageTitle}` : "Open image"
---

<a
  class="glightbox lightbox-image"
  href={imageHref}
  data-type="image"
  data-gallery={gallery}
  data-title={imageTitle}
  data-description={description}
  aria-label={ariaLabel}
>
  {
    typeof src === "string" ? (
      <img
        src={src}
        alt={alt}
        class={imageClass}
        decoding={decoding}
        loading={loading}
      />
    ) : (
      <Picture
        src={src}
        alt={alt}
        formats={formats}
        class={imageClass}
        decoding={decoding}
        loading={loading}
      />
    )
  }
</a>

<script>
  import "glightbox/dist/css/glightbox.min.css"

  type LightboxInstance = {
    destroy: () => void
    reload: () => void
  }

  type GLightboxModule = {
    default: (options: Record<string, unknown>) => LightboxInstance
  }

  type LightboxState = {
    instance: LightboxInstance | undefined
    isListening: boolean | undefined
  }

  const windowWithLightbox = window as Window & {
    bwsLightbox?: LightboxState
  }
  const state = (windowWithLightbox.bwsLightbox ??= {
    instance: undefined,
    isListening: undefined,
  })

  const initLightbox = async () => {
    const lightboxLinks = document.querySelectorAll(".glightbox")

    if (lightboxLinks.length === 0) {
      state.instance?.destroy()
      state.instance = undefined
      return
    }

    if (state.instance) {
      state.instance.reload()
      return
    }

    const { default: GLightbox } = (await import(
      "glightbox"
    )) as GLightboxModule

    state.instance = GLightbox({
      selector: ".glightbox",
      touchNavigation: true,
      keyboardNavigation: true,
      loop: false,
      zoomable: true,
      draggable: true,
      openEffect: "zoom",
      closeEffect: "zoom",
      slideEffect: "slide",
    })
  }

  if (!state.isListening) {
    document.addEventListener("astro:page-load", initLightbox)
    state.isListening = true
  }

  void initLightbox()
</script>
