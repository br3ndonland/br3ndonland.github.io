---
import { Picture } from "astro:assets"
import type { ImageMetadata, ImageOutputFormat } from "astro"
import { PICTURE_FORMATS } from "@consts"
import LightboxInit from "./LightboxInit.astro"

interface Props {
  alt?: string | undefined
  decoding?: "async" | "auto" | "sync" | null | undefined
  description?: string | undefined
  formats?: ImageOutputFormat[] | undefined
  gallery?: string | undefined
  height?: number | string | undefined
  imageClass?: string | undefined
  loading?: "eager" | "lazy" | null | undefined
  thumbnail?: ImageMetadata | string | undefined
  thumbnailAlt?: string | undefined
  thumbnailClass?: string | undefined
  src: string
  title?: string | undefined
  width?: number | string | undefined
}

const {
  alt,
  decoding = "async",
  description,
  formats = PICTURE_FORMATS,
  gallery,
  height,
  imageClass,
  loading = "lazy",
  thumbnail,
  thumbnailAlt,
  thumbnailClass,
  src,
  title,
  width,
} = Astro.props

const videoTitle = title ?? thumbnailAlt ?? alt
const ariaLabel = videoTitle ? `Open video: ${videoTitle}` : "Open video"
const thumbnailAltText = thumbnailAlt ?? alt ?? title ?? ""
const videoHeight = typeof height === "number" ? `${height}px` : height
const videoWidth = typeof width === "number" ? `${width}px` : width
const videoThumbnailClass = [
  "lightbox-video-thumbnail",
  thumbnailClass ?? imageClass,
]
  .filter(Boolean)
  .join(" ")
const hasDefaultSlot = Astro.slots.has("default")
---

<a
  class="glightbox lightbox-video"
  href={src}
  data-type="video"
  data-video-provider="local"
  data-gallery={gallery}
  data-title={videoTitle}
  data-description={description}
  data-width={videoWidth}
  data-height={videoHeight}
  aria-label={ariaLabel}
>
  {
    thumbnail ? (
      typeof thumbnail === "string" ? (
        <img
          src={thumbnail}
          alt={thumbnailAltText}
          class={videoThumbnailClass}
          decoding={decoding}
          loading={loading}
        />
      ) : (
        <Picture
          src={thumbnail}
          alt={thumbnailAltText}
          formats={formats}
          class={videoThumbnailClass}
          decoding={decoding}
          loading={loading}
        />
      )
    ) : hasDefaultSlot ? (
      <slot />
    ) : (
      <span class={`${videoThumbnailClass} lightbox-video-fallback`}>
        {videoTitle ?? "Video"}
      </span>
    )
  }
  <span class="lightbox-video-frame" aria-hidden="true"></span>
</a>

<LightboxInit />
