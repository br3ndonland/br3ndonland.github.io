---
import type { CollectionEntry } from "astro:content"
import { Picture } from "astro:assets"
import Icon from "./Icon.astro"
import SVGLogo from "./SVGLogo.astro"
import { PICTURE_FORMATS, PROJECT_LOGOS } from "@consts"

interface Props {
  entry: CollectionEntry<"projects" | "work">
}

const { entry } = Astro.props
const image = entry.data.image.src
const logo =
  entry.collection === "projects"
    ? PROJECT_LOGOS[entry.id as keyof typeof PROJECT_LOGOS]
    : undefined
---

<a class="card" href={`/${entry.collection}/${entry.id}`}>
  <h3 class="title">
    {entry.data.title}
    <Icon icon="arrow-right" size="1.2em" />
  </h3>
  {
    logo ? (
      <SVGLogo context="card" {...logo} />
    ) : typeof image === "string" ? (
      <img
        src={image}
        alt={entry.data.image.alt}
        decoding="async"
        loading="lazy"
      />
    ) : (
      <Picture
        src={image}
        alt={entry.data.image.alt}
        formats={PICTURE_FORMATS}
        decoding="async"
        loading="lazy"
      />
    )
  }
</a>

<style>
  .card {
    background: var(--gradient-subtle);
    border-radius: 1rem;
    border: 1px solid var(--gray-800);
    box-shadow: var(--shadow-sm);
    display: grid;
    font-family: var(--font-brand);
    grid-template: auto 1fr / auto 1fr;
    height: 10rem;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow var(--theme-transition);
  }

  .card:hover {
    box-shadow: var(--shadow-md);
  }

  .title {
    background: var(--gray-999);
    border-radius: 0.5rem;
    color: var(--gray-200);
    grid-area: 1 / 1 / 2 / 2;
    margin: 0.5rem;
    padding: 0.5rem 1rem;
    z-index: 1;
  }

  img,
  picture,
  :global(svg-logo) {
    grid-area: 1 / 1 / 3 / 3;
    height: 100%;
    width: 100%;
  }

  img,
  picture {
    object-fit: cover;
  }

  @media (min-width: 50em) {
    .card {
      height: 12rem;
    }
  }

  @media (min-width: 75em) {
    .card {
      border-radius: 2rem;
      height: 20rem;
    }

    .title {
      border-radius: 1rem;
    }
  }
</style>
