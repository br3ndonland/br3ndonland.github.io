{
  "ignorePaths": [
    ".astro",
    "**/*changelog.md",
    "CHANGELOG.md",
    "coverage",
    "dist",
    "node_modules",
    "tests/fixtures"
  ],
  "ignoreRegExpList": ["/(`{3})[\\s\\S]+?\\1/g", "/`([\\s\\S]+?)`/g"],
  "languageSettings": [
    {
      "languageId": "python",
      "includeRegExpList": ["/#.*/", "/('''|\"\"\")[^\\1]+?\\1/g"]
    },
    {
      "languageId": "javascript",
      "includeRegExpList": ["CStyleComment"]
    },
    {
      "languageId": "json",
      "includeRegExpList": ["CStyleComment"]
    },
    {
      "languageId": "typescript",
      "includeRegExpList": ["CStyleComment"]
    }
  ],
